# User and Permissions Management
PUID=1000
PGID=1000
TZ=America/Toronto

# Directory Paths
DOCKER_DIR=/home/user/docker
MEDIA_DIR=/home/user/data

# Gluetun openvpn
OPENVPN_PROVIDER=
OPENVPN_USERNAME=
OPENVPN_PASSWORD=
SERVER_REGIONS=
LOCAL_NETWORK=192.168.1.0/24

# Plex Registration Token (Generate at https://www.plex.tv/claim)
# Note: Tokens expire after 4 minutes. Paste and start containers quickly!
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxx