# User and Permissions Management
PUID=1000
PGID=1000
TZ=America/Toronto

# Directory Paths
DOCKER_DIR=/home/user/docker
MEDIA_DIR=/home/user/data

# Transmission
OPENVPN_PROVIDER=
OPENVPN_USERNAME=
OPENVPN_PASSWORD=
SERVER_REGIONS=
# CIDR(s) of networks that should bypass the VPN tunnel. Must include the
# subnet your machine is on, or the web UI on :9091 will be unreachable.
# Comma-separated for multiple networks (e.g. "192.168.0.0/16,10.0.0.0/8").
LOCAL_NETWORK=192.168.1.0/24

# Plex Registration Token (Generate at https://www.plex.tv/claim)
# Note: Tokens expire after 4 minutes. Paste and start containers quickly!
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxx